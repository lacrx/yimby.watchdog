#!/bin/bash
# Civic monitoring pipeline — three modes:
#
#   civic-pipeline full    — claude -p (subscription) + Whisper API.
#   civic-pipeline hybrid  — claude -p (subscription) + Whisper API.
#   civic-pipeline local   — claude -p (subscription) + faster-whisper. Zero API cost.
#
# Pipeline order: GATHER everything, THEN process.
#   Gather: fetch docs (9 agencies) → fetch permits → intel feeds → discover videos
#   Process: merge meetings → monthly rollup (meetings + permits + intel) → extract JSONL
#
# Options:
#   --deep              Download staff reports (not just agendas/minutes)
#   --force             Re-process already summarized/extracted documents
#   --years N           How many years back to fetch (default: 1)
#   --transcribe        Also transcribe meeting videos
#   --hot-only          Extract recent meetings only (skip backlog). Use for forward-facing cron.
#   --extract-until H   Stop cold extraction at hour H (0-23). Ignored with --hot-only.
#
# Cron (forward-facing only — backlog extraction is a separate job via extract-backlog):
#   0 1 * * *    cd ~/repos/yimby.watchdog && ./civic-pipeline local --deep --hot-only
#   0 18 * * 2-5 cd ~/repos/yimby.watchdog && ./civic-pipeline local --deep --hot-only

set -euo pipefail
cd "$(dirname "$0")"
export PATH="$HOME/.local/bin:$PATH"
source .venv/bin/activate
[ -f .env ] && set -a && source .env && set +a
unset ANTHROPIC_API_KEY  # extraction uses claude -p via subscription, not paid API

# ── Overlap protection ──
PIDFILE="data/.pipeline.pid"
if [ -f "$PIDFILE" ]; then
    OLD_PID=$(cat "$PIDFILE")
    if kill -0 "$OLD_PID" 2>/dev/null; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Pipeline already running (PID $OLD_PID). Killing stale run."
        kill "$OLD_PID" 2>/dev/null || true
        sleep 2
        kill -9 "$OLD_PID" 2>/dev/null || true
    fi
fi
echo $$ > "$PIDFILE"
trap 'rm -f "$PIDFILE"' EXIT

PHASE_TIMEOUT=1800  # 30 min max per scraper phase

run_with_timeout() {
    local label="$1"; shift
    timeout "$PHASE_TIMEOUT" "$@" && return 0
    local rc=$?
    if [ "$rc" -eq 124 ]; then
        log "$label timed out after ${PHASE_TIMEOUT}s — killed."
    else
        log "$label failed (exit $rc) — continuing."
    fi
    return 0
}

sync_to_s3() {
    local prefix="$1"; local local_path="$2"; local storage_class="${3:-STANDARD}"
    shift 3
    [ -z "${WATCHDOG_S3_BUCKET:-}" ] && return 0
    aws s3 sync "$local_path" "s3://${WATCHDOG_S3_BUCKET}/${prefix}" \
        --storage-class "$storage_class" --no-progress --size-only \
        "$@" >> data/s3-sync.log 2>&1 || log "S3 sync failed for $prefix (non-fatal)"
}

MODE="${1:-hybrid}"
shift 2>/dev/null || true

DEEP=""
FORCE=""
YEARS="1"
TRANSCRIBE=""
EXTRACT_CUTOFF=""
HOT_ONLY=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --deep)           DEEP="--deep"; shift ;;
        --force)          FORCE="--force"; shift ;;
        --years)          YEARS="$2"; shift 2 ;;
        --transcribe)     TRANSCRIBE="1"; shift ;;
        --extract-until)  EXTRACT_CUTOFF="$2"; shift 2 ;;
        --hot-only)       HOT_ONLY="1"; shift ;;
        *)                echo "Unknown option: $1"; exit 1 ;;
    esac
done

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$MODE] $*"
}

case "$MODE" in
    full|hybrid|local) ;;
    sync-and-extract)
        # AWS split mode: pull from S3, extract locally, push back
        exec ./extract-local $FORCE $([ -n "$EXTRACT_CUTOFF" ] && echo "--extract-until $EXTRACT_CUTOFF")
        ;;
    *) echo "Usage: civic-pipeline <full|hybrid|local|sync-and-extract> [--deep] [--force] [--years N] [--transcribe] [--extract-until H]"
       echo ""
       echo "Modes:"
       echo "  full              — Claude API + Whisper API (bulk, ~\$44/full-run)"
       echo "  hybrid            — claude -p + Whisper API (daily, ~\$0.90/meeting transcription only)"
       echo "  local             — claude -p + faster-whisper (zero API cost)"
       echo "  sync-and-extract  — Pull from S3, extract via claude -p, push back (AWS split mode)"
       exit 1 ;;
esac

case "$MODE" in
    full)          ;; # Whisper API
    hybrid|local)  ;; # faster-whisper
esac

log "Starting civic pipeline (mode=$MODE)"

# ═══════════════════════════════════════════
# PHASE 0: PREFLIGHT — verify endpoints before fetching
# ═══════════════════════════════════════════

log "Running preflight health checks..."
PREFLIGHT_RC=0
python3 pipeline_preflight.py >> data/preflight.log 2>&1 || PREFLIGHT_RC=$?
if [ "$PREFLIGHT_RC" -eq 2 ]; then
    log "PREFLIGHT ABORT: All agencies failing — likely network issue. Stopping pipeline."
    exit 1
elif [ "$PREFLIGHT_RC" -eq 1 ]; then
    log "Preflight: some agencies unhealthy (see data/preflight.log). Continuing with healthy ones."
fi
log "Preflight done."

# ═══════════════════════════════════════════
# PHASE 1: GATHER — collect all raw sources
# ═══════════════════════════════════════════

# ── 1a: Fetch meeting documents (all enabled agencies) ──
while IFS='|' read -r SLUG PLATFORM NAME AGENCY_YEARS; do
    LOG_FILE="data/${SLUG}/watch.log"
    mkdir -p "data/${SLUG}"
    AGENCY_DEEP=""
    # Only pass --deep to agencies configured for it
    if python3 -c "import yaml; c=yaml.safe_load(open('agencies.yaml')); exit(0 if c['agencies']['$SLUG'].get('deep_fetch') else 1)" 2>/dev/null; then
        AGENCY_DEEP="$DEEP"
    fi
    # Per-agency lookback: use agency's lookback_months if set, else global --years
    FETCH_YEARS="${AGENCY_YEARS:-$YEARS}"

    log "Fetching $NAME meetings (${FETCH_YEARS}y lookback)..."
    case "$PLATFORM" in
        legistar_html)
            run_with_timeout "$NAME fetch" python3 scrapers/oceanside.py fetch $AGENCY_DEEP --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        legistar_odata)
            run_with_timeout "$NAME fetch" python3 scrapers/sdcounty.py fetch --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        escribe)
            run_with_timeout "$NAME fetch" python3 scrapers/sandag.py fetch --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        custom_html)
            run_with_timeout "$NAME fetch" python3 scrapers/nctd.py fetch >> "$LOG_FILE" 2>&1
            ;;
        coastal_api)
            run_with_timeout "$NAME fetch" python3 scrapers/coastal.py fetch --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        granicus)
            run_with_timeout "$NAME fetch" python3 scrapers/granicus.py fetch --agency "$SLUG" $AGENCY_DEEP --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        civicplus)
            run_with_timeout "$NAME fetch" python3 scrapers/civicplus.py fetch --agency "$SLUG" $AGENCY_DEEP --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        civicclerk)
            run_with_timeout "$NAME fetch" python3 scrapers/civicclerk.py fetch --agency "$SLUG" $AGENCY_DEEP --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        carlsbad_cms)
            run_with_timeout "$NAME fetch" python3 scrapers/carlsbad.py fetch $AGENCY_DEEP --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        solana_drupal)
            run_with_timeout "$NAME fetch" python3 scrapers/solana_beach.py fetch $AGENCY_DEEP --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        municode)
            run_with_timeout "$NAME fetch" python3 scrapers/municode.py fetch --agency "$SLUG" $AGENCY_DEEP --years "$FETCH_YEARS" >> "$LOG_FILE" 2>&1
            ;;
        *)
            log "  $NAME: unknown platform '$PLATFORM', skipping."
            ;;
    esac
    log "$NAME fetch done."
done < <(python3 -c "
import yaml
cfg = yaml.safe_load(open('agencies.yaml'))
for slug, a in cfg['agencies'].items():
    if a.get('enabled', True):
        lb = a.get('lookback_months')
        years = str(-(-lb // 12)) if lb else ''
        print(f\"{slug}|{a['platform']}|{a.get('name', slug)}|{years}\")
")

# ── 1b: Intel feed — check RSS/web for relevant items ──
log "Checking intel feeds..."
run_with_timeout "Intel feed" python3 scrapers/intel_feed.py >> data/intel/feed.log 2>&1
log "Intel feed done."

# ── 1c: Fetch building permits (agencies with permit config) ──
CURRENT_YEAR=$(date '+%Y')
while IFS='|' read -r SLUG NAME; do
    log "Fetching $NAME permits ($CURRENT_YEAR, incremental)..."
    mkdir -p "data/${SLUG}/permits"
    if run_with_timeout "$NAME permits" python3 scrapers/etrakit.py fetch --agency "$SLUG" --year "$CURRENT_YEAR" >> "data/${SLUG}/permits/fetch.log" 2>&1; then
        log "$NAME permits done."
    else
        log "$NAME permits failed — continuing pipeline."
    fi
done < <(python3 -c "
import yaml
cfg = yaml.safe_load(open('agencies.yaml'))
for slug, a in cfg['agencies'].items():
    if a.get('enabled', True) and a.get('permits'):
        print(f\"{slug}|{a.get('name', slug)}\")
")

# ── 1d: Discover new meeting videos ──
log "Discovering new meeting videos..."
run_with_timeout "Video discovery" python3 scrapers/discover_videos.py >> data/video-discovery.log 2>&1
log "Video discovery done."

# ── 1e: Transcribe audio (if enabled) ──
# Only transcribe high-priority meetings by default (City Council, Planning Commission,
# or meetings with housing/zoning keyword hits in agenda text).
# Full/hybrid modes use Whisper API (~$0.006/min); local uses faster-whisper (free).
if [ -n "$TRANSCRIBE" ]; then
    if [ ! -f data/transcribe-batch.json ]; then
        log "  No data/transcribe-batch.json found. Skipping transcription."
    else
        # Filter batch to high-priority meetings only (unless --force)
        BATCH_FILE="data/transcribe-batch.json"
        if [ -z "$FORCE" ]; then
            FILTERED_FILE="data/transcribe-batch-filtered.json"
            python3 -c "
import json
batch = json.loads(open('$BATCH_FILE').read())
high = [e for e in batch if e.get('priority', 'high') == 'high']
low = [e for e in batch if e.get('priority') == 'low']
if low:
    print(f'  Skipping {len(low)} low-priority meetings (use --force to include all)')
open('$FILTERED_FILE', 'w').write(json.dumps(high, indent=2))
print(f'  {len(high)} high-priority meetings to transcribe')
" >> data/transcribe.log 2>&1
            BATCH_FILE="$FILTERED_FILE"
        fi
        BATCH_COUNT=$(python3 -c "import json; b=json.loads(open('$BATCH_FILE').read()); print(len(b))" 2>/dev/null || echo 0)
        log "  Transcribing $BATCH_COUNT meetings"
        if [ "$BATCH_COUNT" -gt 0 ] 2>/dev/null; then
            TRANSCRIBE_OK=true
            case "$MODE" in
                full|hybrid)
                    log "  Transcribing with Whisper API..."
                    python3 transforms/transcribe.py --batch "$BATCH_FILE" \
                        >> data/transcribe.log 2>&1 || TRANSCRIBE_OK=false
                    ;;
                local)
                    log "  Transcribing with faster-whisper (local)..."
                    python3 transforms/transcribe_local.py batch "$BATCH_FILE" \
                        >> data/transcribe.log 2>&1 || TRANSCRIBE_OK=false
                    ;;
            esac
            if [ "$TRANSCRIBE_OK" = true ]; then
                log "Transcription done."
            else
                log "Transcription failed — continuing with extraction."
            fi
        else
            log "  No high-priority meetings to transcribe."
        fi
    fi
fi

# ── S3 sync: raw sources ──
if [ -n "${WATCHDOG_S3_BUCKET:-}" ]; then
    log "Syncing raw sources to S3..."
    # Per-agency documents and meetings
    while IFS='|' read -r SLUG _; do
        if [ -d "data/${SLUG}/documents" ]; then
            sync_to_s3 "archive/${SLUG}/documents/pdfs" "data/${SLUG}/documents" "STANDARD" --exclude "*.txt" --exclude "*.skip" --exclude "*.json"
            sync_to_s3 "raw/${SLUG}/documents/txt" "data/${SLUG}/documents" "STANDARD_IA" --exclude "*.pdf" --exclude "*.skip" --exclude "*.json"
        fi
        if [ -f "data/${SLUG}/doc-index.json" ]; then
            aws s3 cp "data/${SLUG}/doc-index.json" "s3://${WATCHDOG_S3_BUCKET}/raw/${SLUG}/doc-index.json" --quiet || true
        fi
        if [ -d "data/${SLUG}/meetings" ]; then
            sync_to_s3 "metadata/${SLUG}/meetings" "data/${SLUG}/meetings" "STANDARD"
        fi
        if [ -d "data/${SLUG}/permits" ]; then
            sync_to_s3 "operational/${SLUG}/permits" "data/${SLUG}/permits" "STANDARD"
        fi
    done < <(python3 -c "
import yaml
cfg = yaml.safe_load(open('agencies.yaml'))
for slug, a in cfg['agencies'].items():
    if a.get('enabled', True):
        print(f\"{slug}|{a.get('name', slug)}\")
")
    # Shared resources
    sync_to_s3 "archive/audio" "data/audio" "STANDARD"
    sync_to_s3 "operational/intel" "data/intel" "STANDARD"
    sync_to_s3 "raw/transcripts" "data/transcripts" "STANDARD_IA"
    log "S3 sync (raw) done."
fi

# ═══════════════════════════════════════════
# PHASE 2: PROCESS — merge and roll up existing records
# ═══════════════════════════════════════════

# ── 2a: Merge per-document records into per-meeting records ──
log "Merging per-meeting records..."
MERGE_RC=0
python3 transforms/meeting_merge.py >> data/meeting-merge.log 2>&1 || MERGE_RC=$?
if [ "$MERGE_RC" -ne 0 ]; then
    log "WARNING: Meeting merge failed (exit $MERGE_RC). Continuing pipeline."
fi
log "Meeting merge done."

# ── 2b: Monthly rollups (auto-detects stale months) ──
log "Building monthly digests..."
python3 transforms/monthly_rollup.py >> data/monthly-rollup.log 2>&1 || log "WARNING: Monthly rollup failed. Continuing pipeline."
log "Monthly rollups done."

# ═══════════════════════════════════════════
# PHASE 3a: HOT EXTRACT — recent meetings, must complete
# ═══════════════════════════════════════════
# Documents from meetings in the last 14 days. No time limit — these
# must always be processed. Failures are logged loudly.

python3 transforms/extract_structured.py --tally >> data/structured-extraction.log 2>&1 || true

EXTRACT_BEFORE=$(find data/structured -name '*.json' 2>/dev/null | wc -l)

log "Hot extraction (last 14 days)..."
HOT_RC=0
python3 transforms/extract_structured.py --queue hot $FORCE >> data/structured-extraction.log 2>&1 || HOT_RC=$?

EXTRACT_AFTER_HOT=$(find data/structured -name '*.json' 2>/dev/null | wc -l)
HOT_EXTRACTIONS=$((EXTRACT_AFTER_HOT - EXTRACT_BEFORE))

if [ "$HOT_RC" -ne 0 ]; then
    log "WARNING: Hot extraction failed (exit $HOT_RC). Check data/structured-extraction.log"
fi
log "Hot extraction done: $HOT_EXTRACTIONS new."

# ═══════════════════════════════════════════
# PHASE 3b: COLD EXTRACT — backlog, time-bounded, optional
# ═══════════════════════════════════════════
# Only runs if hot succeeded and time remains. Oldest-first.
# Failures are quiet — backlog can wait.

if [ -n "$HOT_ONLY" ]; then
    log "Skipping cold extraction (--hot-only)."
elif [ "$HOT_RC" -eq 0 ] && [ -n "$EXTRACT_CUTOFF" ]; then
    CURRENT_HOUR=$(date +%H)
    if [ "$CURRENT_HOUR" -lt "$EXTRACT_CUTOFF" ]; then
        log "Cold extraction (backlog, until ${EXTRACT_CUTOFF}:00)..."
        python3 transforms/extract_structured.py --queue cold --stop-at "$EXTRACT_CUTOFF" $FORCE \
            >> data/structured-extraction.log 2>&1 || true
        log "Cold extraction done."
    else
        log "No time remaining for cold extraction."
    fi
elif [ "$HOT_RC" -eq 0 ] && [ -z "$EXTRACT_CUTOFF" ]; then
    log "Cold extraction (backlog, limit 50)..."
    python3 transforms/extract_structured.py --queue cold --limit 50 $FORCE \
        >> data/structured-extraction.log 2>&1 || true
    log "Cold extraction done."
fi

EXTRACT_AFTER=$(find data/structured -name '*.json' 2>/dev/null | wc -l)
NEW_EXTRACTIONS=$((EXTRACT_AFTER - EXTRACT_BEFORE))

if [ "$NEW_EXTRACTIONS" -gt 0 ]; then
    log "Extractions: $HOT_EXTRACTIONS hot + $((NEW_EXTRACTIONS - HOT_EXTRACTIONS)) cold = $NEW_EXTRACTIONS total."
else
    log "No new extractions."
fi

# ── S3 sync: structured data ──
if [ -n "${WATCHDOG_S3_BUCKET:-}" ]; then
    log "Syncing structured data to S3..."
    sync_to_s3 "structured/records" "data/structured" "STANDARD" --exclude "meetings/*" --exclude "monthly/*" --exclude "*.jsonl" --exclude "*.log" --exclude "*.skip"
    sync_to_s3 "structured/meetings" "data/structured/meetings" "STANDARD"
    sync_to_s3 "structured/monthly" "data/structured/monthly" "STANDARD"
    aws s3 cp data/structured/all-records.jsonl "s3://${WATCHDOG_S3_BUCKET}/structured/all-records.jsonl" --quiet 2>/dev/null || true
    aws s3 cp data/structured/meetings-combined.jsonl "s3://${WATCHDOG_S3_BUCKET}/structured/meetings-combined.jsonl" --quiet 2>/dev/null || true
    log "S3 sync (structured) done."
fi

# ═══════════════════════════════════════════
# PHASE 5: DOCTOR — diagnose errors and self-heal
# ═══════════════════════════════════════════

log "Running pipeline doctor..."
python3 pipeline_doctor.py >> data/pipeline-doctor-run.log 2>&1
log "Doctor done."

log "Pipeline complete."
