# Bootstrap config — jurisdiction-specific settings live in SSM Parameter Store
# or config.local.yaml (for local development without AWS).

# AWS region for SSM and S3
AWS_REGION=us-west-2

# SSM prefix — all jurisdiction config lives under this path.
# Each deployment gets its own prefix.
SSM_PREFIX=/civic-monitor/

# S3 bucket for pipeline data (optional — pipeline works without it)
# WATCHDOG_S3_BUCKET=yimby-watchdog-data

# Anthropic API key — only needed for 'api' mode bulk processing.
# The pipeline uses claude -p (subscription) and strips this from the environment.
# ANTHROPIC_API_KEY=sk-ant-...
