#!/bin/bash
# Historical catch-up — reprocess full 2020-present dataset.
#
# Runs 1am–7am nightly alongside the regular 3am daily pipeline.
# Transcription runs in background while extraction processes docs.
# Both resumable across nights.
#
# Once all workstreams complete, regenerates executive summaries
# and removes itself from cron.
#
# Cron (added alongside existing 3am daily):
#   0 1 * * * cd ~/repos/civics && ./civic-catchup >> data/catchup-cron.log 2>&1
#
# Manual override: STOP_HOUR=23 ./civic-catchup

set -euo pipefail
cd "$(dirname "$0")"
export PATH="$HOME/.local/bin:$PATH"
source .venv/bin/activate

YEARS=7
STOP_HOUR=${STOP_HOUR:-7}

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [catchup] $*"
}

log "═══════════════════════════════════════════"
log "Starting historical catch-up (2020-present)"
log "═══════════════════════════════════════════"

# ── Phase 1: Gather all meeting sources back to 2020 ──

log "Fetching Oceanside meetings (${YEARS} years)..."
python oceanside.py fetch --deep --years "$YEARS" >> data/watch.log 2>&1
log "Oceanside fetch done."

log "Fetching NCTD meetings..."
python nctd.py fetch >> data/nctd-watch.log 2>&1
log "NCTD fetch done."

# Video discovery + transcription disabled until faster solution found
# log "Discovering videos..."
# python discover_videos.py >> data/video-discovery.log 2>&1

# ── Phase 2: Extraction first, then transcription ──
# Both are CPU-bound. Running sequentially avoids thrashing 8 cores.
# Extraction is higher-value (feeds monthly rollups), so it goes first.
# Transcripts get their own extraction pass on subsequent nights.

log "Force re-extracting structured records (stop at ${STOP_HOUR}:00)..."
EXTRACT_OUTPUT=$(python extract_structured.py --force --stop-at "$STOP_HOUR" 2>&1 | tee -a data/structured-extraction.log)
log "Structured extraction done."

EXTRACT_DONE=true
if echo "$EXTRACT_OUTPUT" | grep -q "remaining, will resume"; then
    REMAINING=$(echo "$EXTRACT_OUTPUT" | grep "remaining" | grep -oP '\d+ remaining' | grep -oP '^\d+')
    log "Extraction stopped early — ${REMAINING} sources remaining."
    EXTRACT_DONE=false
fi

# ── Phase 3: Intel backfill ──

INTEL_DONE=true
if [ "$(date '+%H')" -lt "$STOP_HOUR" ]; then
    log "Backfilling intel sources (stop at ${STOP_HOUR}:00)..."
    BACKFILL_OUTPUT=$(python intel_backfill.py --stop-at "$STOP_HOUR" 2>&1 | tee -a data/intel/backfill.log)
    log "Intel backfill done."

    if echo "$BACKFILL_OUTPUT" | grep -q "Stopping at"; then
        INTEL_DONE=false
        log "Intel backfill incomplete — will resume next run."
    fi
    if echo "$BACKFILL_OUTPUT" | grep -q "ALL SOURCES BACKFILLED"; then
        log "Intel backfill complete."
    fi
else
    log "No time remaining for intel backfill — will run next night."
    INTEL_DONE=false
fi

# ── Phase 4: Merge + rollup (with whatever extraction produced) ──

log "Merging per-meeting records..."
python meeting_merge.py >> data/meeting-merge.log 2>&1
log "Meeting merge done."

log "Rebuilding all monthly digests..."
python monthly_rollup.py --force >> data/monthly-rollup.log 2>&1
log "Monthly rollups done."

log "Updating skill intel..."
python update_skill_intel.py >> data/intel/feed.log 2>&1
log "Skill intel updated."

# ── Phase 5: Executive summaries + self-remove (only when fully caught up) ──

if [ "$EXTRACT_DONE" = true ] && [ "$INTEL_DONE" = true ]; then
    log "All workstreams complete. Running executive summaries..."
    python executive_summaries.py --source monthly --mode local >> data/catchup-exec.log 2>&1
    log "Executive summaries done."

    # ── Self-remove from cron ──
    log "══════════════════════════════════════"
    log "CATCH-UP COMPLETE. Removing from cron."
    log "══════════════════════════════════════"
    crontab -l 2>/dev/null | grep -v 'civic-catchup' | crontab -
else
    log "Not fully caught up yet — executive summaries deferred."
    [ "$EXTRACT_DONE" = false ] && log "  Extraction: incomplete"
    [ "$INTEL_DONE" = false ] && log "  Intel backfill: incomplete"
fi

# ── Transcription disabled until we find a faster solution ──
# 175 videos × ~50 min each on CPU = too slow for nightly window.
# Re-enable once we have GPU acceleration or a faster approach.

log "Tonight's catch-up run finished."
